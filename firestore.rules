rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: progress
    // Document ID: {userId} (The UID of the user)
    // Fields:
    //   - completed: list of strings (task IDs)
    //   - ratings: map of numbers (task ID -> rating 1-5)
    //   - notes: map of strings (task ID -> note text, max 2000 chars)
    //   - ownerId: string (must match document ID and auth.uid)
    //   - updatedAt: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields() {
      return request.resource.data.keys().hasAll(['completed', 'ratings', 'notes', 'ownerId']);
    }

    function isValidProgress() {
      let data = request.resource.data;
      
      // Basic type checks
      let validTypes = data.completed is list && 
                       data.ratings is map && 
                       data.notes is map && 
                       data.ownerId is string;
                       
      // Owner ID must match the document ID
      let validOwner = data.ownerId == request.auth.uid;
      
      // Size limits to prevent DoS/Resource Exhaustion
      // Max 1000 completed tasks, max 1000 ratings, max 1000 notes
      let validSizes = data.completed.size() <= 1000 &&
                       data.ratings.size() <= 1000 &&
                       data.notes.size() <= 1000;
                       
      return validTypes && validOwner && validSizes;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /progress/{userId} {
      // PUBLIC READ: Anyone can read the progress (Live Portfolio)
      allow read: if true;
      
      // ADMIN WRITE: Only the owner can create or update their own document
      allow create: if isOwner(userId) && hasRequiredFields() && isValidProgress();
      allow update: if isOwner(userId) && hasRequiredFields() && isValidProgress();
      allow delete: if false; // Progress should not be deleted
    }
  }
}
