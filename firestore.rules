rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAdmin() {
      // Разрешаем доступ только конкретному email
      return request.auth != null && request.auth.token.email == 'genialnee@gmail.com';
    }

    function isValidProgress() {
      let data = request.resource.data;
      
      // Проверяем типы данных (все они - объекты/словари)
      let validTypes = (!('completed' in data) || data.completed is map) && 
                       (!('ratings' in data) || data.ratings is map) && 
                       (!('notes' in data) || data.notes is map) &&
                       (!('lastUpdated' in data) || data.lastUpdated is string);
                       
      return validTypes;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /system/config {
      // Секретный документ для "Пинга" прав. 
      // Прочитать может только админ.
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /progress/{docId} {
      // PUBLIC READ: Любой может смотреть прогресс
      allow read: if true;
      
      // ADMIN WRITE: Только админ может сохранять изменения
      allow create, update: if isAdmin() && isValidProgress();
      allow delete: if false;
    }

    match /content/{docId} {
      // PUBLIC READ: Любой может читать контент сайта (историю, план)
      allow read: if true;
      
      // ADMIN WRITE: Только админ может редактировать контент
      allow create, update, delete: if isAdmin();
    }
  }
}
